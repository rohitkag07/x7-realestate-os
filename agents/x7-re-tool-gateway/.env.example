PORT=8081
NODE_ENV=production
AGENT_SECRET=replace-with-shared-secret

# WhatsApp Business (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Meta publish (Instagram + Facebook)
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_FB_PAGE_ID=

# Higgsfield (CLI auth or API key)
HIGGSFIELD_API_KEY=

# Remotion render
REMOTION_MODE=lambda
REMOTION_LAMBDA_FN=
REMOTION_LAMBDA_REGION=us-east-1
REMOTION_SERVE_URL=
REMOTION_PROJECT_DIR=../../remotion

# Razorpay UPI
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
DEFAULT_UPI_VPA=builder@upi
DEFAULT_UPI_NAME=Builder
