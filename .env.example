# WhatsAI Assistant - Vercel serverless runtime

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY= # accepted legacy alias

# Meta WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=
WHATSAPP_GRAPH_VERSION=v22.0

# Secures /api/cron/followup-scheduler. Generate a long random value.
CRON_SECRET=

# Runtime switches
DYNAMIC_KEYWORD_ENGINE_ENABLED=true
HINGLISH_FUZZY_MATCHING_ENABLED=true
KNOWLEDGE_BASE_ENABLED=true

# Dashboard/runtime URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
# WHATSAI_APP_URL=http://localhost:3000 # used by npm run prove:whatsai

# Default tenant context for dashboard-only flows
DEFAULT_BUSINESS_ID=
DEFAULT_BUILDER_ID=
DEFAULT_PROJECT_ID=
DEFAULT_ASSISTANT_PLAYBOOK_ID=
DEFAULT_VERTICAL=real_estate
OWNER_HANDOFF_PHONE=

# Optional lead-source integrations
JUSTDIAL_WEBHOOK_SECRET=
INDIAMART_CRM_KEY=

# Legacy PM2/Cloud Run agent URLs are intentionally not required.
